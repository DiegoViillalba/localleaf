{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capabilities for LocalLeaf",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:scope-home-recursive",
    "fs:scope-document-recursive",
    "fs:scope-desktop-recursive",
    "dialog:default",
    "dialog:allow-open",
    "shell:default"
  ]
}
